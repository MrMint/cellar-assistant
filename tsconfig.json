{
  "extends": "@cellar-assistant/typescript-config/nextjs.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "webworker"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "functions",
    "packages",
    "**/*.test.ts",
    "**/*.test.tsx",
    "public/sw.js"
  ]
}
